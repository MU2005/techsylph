# Build + Runtime Required: Sanity read access
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Runtime Required: Sanity server-side write access (API routes)
SANITY_API_TOKEN=your_sanity_write_token_here

# Runtime Required: Email delivery for contact/RFQ notifications
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM=TechSylph <notifications@techsylph.shop>
ADMIN_EMAIL=hello@techsylph.shop

# Runtime Optional: Error tracking (recommended in production)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Runtime Optional: Analytics (recommended in production)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Runtime Optional: WhatsApp CTA
NEXT_PUBLIC_WHATSAPP_NUMBER=+923001234567
