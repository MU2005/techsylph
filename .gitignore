# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/

# Production / bundlers
/build
/dist
.turbo

# Debug & logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Env & secrets (broad ignore, then allow the committed template)
.env*
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Tooling caches
.eslintcache
.prettiercache

# OS & editors
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Sanity local studio cache (if present)
.sanity/

# Bulk import: generated NDJSON + local image drops (CSV + README stay tracked)
scripts/import/**/*.ndjson
scripts/import/images/*
!scripts/import/images/.gitkeep
